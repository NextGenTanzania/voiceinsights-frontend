  Cache-Control: no-cache

/sample-reports.html
  Cache-Control: no-cache, no-store, must-revalidate

/flagship-sample-report.html
  Cache-Control: no-cache, no-store, must-revalidate

# RC1 finding: Cloudflare Pages *merges* Cache-Control directives from every
# matching rule rather than letting a more specific rule replace a broader
# one — confirmed live: config.js's intended "no-cache" was actually being
# served as "public, max-age=86400, must-revalidate" because the blanket
# /assets/* rule below also matched and its max-age got merged in. That
# meant a genuinely critical fix (this sprint's optimistic-concurrency
# change) could sit invisible in an already-cached browser or Cloudflare's
# own edge cache for up to 24 hours after a real deploy — reproduced
# directly (cf-cache-status: HIT serving pre-fix decision-detail-page.js
# nearly 20 minutes after the corrected version was live at origin).
# Logic files (JS/CSS) now get their own rule with no competing wildcard
# match, so "no-cache, must-revalidate" actually takes effect; only true
# static assets (images) keep the long cache.
/assets/js/*
  Cache-Control: no-cache, must-revalidate

/assets/css/*
  Cache-Control: no-cache, must-revalidate

/assets/img/*
  Cache-Control: public, max-age=86400
