/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(self), geolocation=(self), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  X-Permitted-Cross-Domain-Policies: none
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net; img-src 'self' data: blob: https:; media-src 'self' blob: https:; connect-src 'self' https://voiceinsights-api.kitentyatsnp.workers.dev; font-src 'self' data: https:; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests

/sw.js
  Service-Worker-Allowed: /
  Cache-Control: no-cache

/sample-reports.html
  Cache-Control: no-cache, no-store, must-revalidate

/flagship-sample-report.html
  Cache-Control: no-cache, no-store, must-revalidate

/assets/js/config.js
  Cache-Control: no-cache, must-revalidate

/assets/*
  Cache-Control: public, max-age=86400
